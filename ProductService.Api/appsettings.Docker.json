{

  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=ProductServiceDb;Username=postgres;Password=postgres123"
  },

  "Jwt": {
    "Key": "THIS_IS_SUPER_SECRET_KEY_1234567890",
    "Issuer": "UserService",
    "Audience": "ECommerceClient",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],

    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },

    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],

    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },

  "Redis": {
    "ConnectionString": "redis:6379"
  },

  "AllowedHosts": "*"
}
