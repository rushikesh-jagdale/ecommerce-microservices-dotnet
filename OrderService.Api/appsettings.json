{
  "ConnectionStrings": {
    "DefaultConnection": "Server=DESKTOP-LLJCCRJ\\SQLEXPRESS;Database=OrderServiceDb;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "THIS_IS_SUPER_SECRET_KEY_1234567890",
    "Issuer": "UserService",
    "Audience": "ECommerceClient",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],

    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },

    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],

    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },

  "ProductService": {
    "BaseUrl": "https://localhost:7143/"
  },

  "RabbitMQ": {
    "Host": "localhost"
  },
  "AllowedHosts": "*"
}
