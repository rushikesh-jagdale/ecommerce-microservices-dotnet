{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "userservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/gateway/auth/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post" ],
      "SwaggerKey": "user"
    },
    {
      "DownstreamPathTemplate": "/api/products/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "productservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/gateway/products/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ],
      "SwaggerKey": "product"
    },
    {
      "DownstreamPathTemplate": "/api/orders/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "orderservice",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/gateway/orders/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post" ],
      "SwaggerKey": "order"
    }
  ],

  "SwaggerEndPoints": [
    {
      "Key": "user",
      "Config": [
        {
          "Name": "User Service",
          "Version": "v1",
          "Url": "http://userservice:8080/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "product",
      "Config": [
        {
          "Name": "Product Service",
          "Version": "v1",
          "Url": "http://productservice:8080/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "order",
      "Config": [
        {
          "Name": "Order Service",
          "Version": "v1",
          "Url": "http://orderservice:8080/swagger/v1/swagger.json"
        }
      ]
    }
  ],

  "GlobalConfiguration": {
    "BaseUrl": "http://apigateway:8080"
  }
}