{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "userservice-d836.onrender.com",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/gateway/auth/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post" ],
      "SwaggerKey": "user"
    },
    {
      "DownstreamPathTemplate": "/api/products/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "productservice-eoxi.onrender.com",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/gateway/products/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ],
      "SwaggerKey": "product"
    },
    {
      "DownstreamPathTemplate": "/api/orders/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "orderservice-n9st.onrender.com",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/gateway/orders/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post" ],
      "SwaggerKey": "order"
    }
  ],

  "SwaggerEndPoints": [
    {
      "Key": "user",
      "Config": [
        {
          "Name": "User Service",
          "Version": "v1",
          "Url": "https://userservice-d836.onrender.com/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "product",
      "Config": [
        {
          "Name": "Product Service",
          "Version": "v1",
          "Url": "https://productservice-eoxi.onrender.com/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "order",
      "Config": [
        {
          "Name": "Order Service",
          "Version": "v1",
          "Url": "https://orderservice-n9st.onrender.com/swagger/v1/swagger.json"
        }
      ]
    }
  ],

  "GlobalConfiguration": {
    "BaseUrl": "https://apigateway.onrender.com"
  }
}
